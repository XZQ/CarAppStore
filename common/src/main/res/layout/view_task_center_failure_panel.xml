<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/spacing_14dp"
    android:visibility="gone">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_task_card_failed"
        android:orientation="vertical"
        android:padding="@dimen/spacing_16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

    <TextView
        android:id="@+id/tvFailureTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/ui_task_failure_title"
        android:textColor="@color/car_text_primary"
        android:textSize="@dimen/text_sm"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvFailureDesc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_6dp"
        android:text="@string/ui_task_failure_hint"
        android:textColor="@color/car_text_secondary"
        android:textSize="@dimen/text_xs" />

    <TextView
        android:id="@+id/tvFailureHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_8dp"
        android:text="@string/ui_task_failure_refresh_hint"
        android:textColor="@color/car_text_secondary"
        android:textSize="@dimen/text_xs" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_12dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnFailurePrimary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/spacing_6dp"
            android:layout_weight="1"
            android:text="@string/ui_batch_retry_failed" />

        <Button
            android:id="@+id/btnFailureSecondary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_6dp"
            android:layout_weight="1"
            android:text="@string/ui_clear_failed_state" />
    </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
