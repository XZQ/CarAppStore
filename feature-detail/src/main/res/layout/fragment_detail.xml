<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_activity">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_panel"
            android:orientation="vertical"
            android:padding="@dimen/spacing_18dp">

            <TextView
                android:id="@+id/tvDetailName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/car_text_primary"
                android:textSize="@dimen/text_3xl"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvDetailVersion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_8dp"
                android:textColor="@color/car_text_muted"
                android:textSize="@dimen/text_sm" />

            <TextView
                android:id="@+id/tvDetailDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_14dp"
                android:textColor="@color/car_text_secondary"
                android:textSize="@dimen/text_md" />

            <TextView
                android:id="@+id/tvPolicyPrompt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_14dp"
                android:background="@drawable/bg_tag_warning"
                android:padding="@dimen/spacing_10dp"
                android:textColor="@color/car_text_primary"
                android:textSize="@dimen/text_sm_13"
                android:visibility="gone" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_16dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="@dimen/spacing_18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ui_task_status"
                android:textColor="@color/car_text_muted"
                android:textSize="@dimen/text_sm_13" />

            <TextView
                android:id="@+id/tvState"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_10dp"
                android:paddingStart="@dimen/spacing_12dp"
                android:paddingTop="@dimen/spacing_7dp"
                android:paddingEnd="@dimen/spacing_12dp"
                android:paddingBottom="@dimen/spacing_7dp"
                android:textColor="@color/car_text_primary"
                android:textSize="@dimen/text_sm_13"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvProgress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_16dp"
                android:textColor="@color/car_text_secondary"
                android:textSize="@dimen/text_sm_15" />

            <ProgressBar
                android:id="@+id/progressDownload"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_8dp"
                android:max="100"
                android:progress="0" />
        </LinearLayout>

        <Button
            android:id="@+id/btnPrimaryAction"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="@dimen/spacing_18dp"
            android:background="@drawable/bg_primary_button"
            android:text="@string/ui_download"
            android:textAllCaps="false"
            android:textColor="@color/car_text_primary"
            android:textSize="@dimen/text_lg_19"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnGoMyApps"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="@dimen/spacing_12dp"
            android:background="@drawable/bg_secondary_button"
            android:text="@string/ui_my_apps"
            android:textAllCaps="false"
            android:textColor="@color/car_text_primary"
            android:textSize="@dimen/text_md_17"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnBackHome"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="@dimen/spacing_12dp"
            android:background="@drawable/bg_secondary_button"
            android:text="@string/ui_back_home"
            android:textAllCaps="false"
            android:textColor="@color/car_text_primary"
            android:textSize="@dimen/text_md_17"
            android:textStyle="bold" />
    </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
