<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_activity">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_20dp">

            <!-- 应用信息面板 -->
            <include
                android:id="@+id/includeDetailAppInfo"
                layout="@layout/include_detail_app_info" />

            <!-- 任务状态面板 -->
            <include
                android:id="@+id/includeDetailTaskStatus"
                layout="@layout/include_detail_task_status" />

            <Button
                android:id="@+id/btnPrimaryAction"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="@dimen/spacing_18dp"
                android:background="@drawable/bg_primary_button"
                android:text="@string/ui_download"
                android:textAllCaps="false"
                android:textColor="@color/car_text_primary"
                android:textSize="@dimen/text_lg_19"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnGoMyApps"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="@dimen/spacing_12dp"
                android:background="@drawable/bg_secondary_button"
                android:text="@string/ui_my_apps"
                android:textAllCaps="false"
                android:textColor="@color/car_text_primary"
                android:textSize="@dimen/text_md_17"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnBackHome"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="@dimen/spacing_12dp"
                android:background="@drawable/bg_secondary_button"
                android:text="@string/ui_back_home"
                android:textAllCaps="false"
                android:textColor="@color/car_text_primary"
                android:textSize="@dimen/text_md_17"
                android:textStyle="bold" />
        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
