<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/spacing_12dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_card_alt"
        android:orientation="vertical"
        android:padding="@dimen/spacing_16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvAppName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/car_text_primary"
            android:textSize="@dimen/text_lg_19"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvState"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="@dimen/spacing_12dp"
            android:paddingTop="@dimen/spacing_6dp"
            android:paddingEnd="@dimen/spacing_12dp"
            android:paddingBottom="@dimen/spacing_6dp"
            android:textColor="@color/car_text_primary"
            android:textSize="@dimen/text_xs"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvDesc"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_10dp"
        android:textColor="@color/car_text_secondary"
        android:textSize="@dimen/text_sm_15" />

    <TextView
        android:id="@+id/tvAction"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_12dp"
        android:paddingStart="@dimen/spacing_12dp"
        android:paddingTop="@dimen/spacing_8dp"
        android:paddingEnd="@dimen/spacing_12dp"
        android:paddingBottom="@dimen/spacing_8dp"
        android:textColor="@color/car_text_primary"
        android:textSize="@dimen/text_sm_13"
        android:textStyle="bold" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
