<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_activity"
    android:padding="@dimen/spacing_16dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_panel"
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:padding="@dimen/spacing_18dp">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/ui_carappstore"
            android:textColor="@color/car_text_primary"
            android:textSize="@dimen/text_3xl"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_6dp"
            android:text="@string/ui_service_center_subtitle"
            android:textColor="@color/car_text_secondary"
            android:textSize="@dimen/text_sm" />
    </LinearLayout>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_12dp"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnNavHome"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:background="@drawable/bg_nav_button"
                android:minWidth="90dp"
                android:paddingStart="@dimen/spacing_18dp"
                android:paddingEnd="@dimen/spacing_18dp"
                android:text="@string/ui_home"
                android:textColor="@color/car_text_primary"
                android:textSize="@dimen/text_md" />

            <Button
                android:id="@+id/btnNavSearch"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginStart="@dimen/spacing_10dp"
                android:background="@drawable/bg_nav_button"
                android:minWidth="90dp"
                android:paddingStart="@dimen/spacing_18dp"
                android:paddingEnd="@dimen/spacing_18dp"
                android:text="@string/ui_search"
                android:textColor="@color/car_text_primary"
                android:textSize="@dimen/text_md" />

            <Button
                android:id="@+id/btnNavDownload"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginStart="@dimen/spacing_10dp"
                android:background="@drawable/bg_nav_button"
                android:minWidth="108dp"
                android:paddingStart="@dimen/spacing_18dp"
                android:paddingEnd="@dimen/spacing_18dp"
                android:text="@string/ui_download_manager"
                android:textColor="@color/car_text_primary"
                android:textSize="@dimen/text_md" />

            <Button
                android:id="@+id/btnNavUpgrade"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginStart="@dimen/spacing_10dp"
                android:background="@drawable/bg_nav_button"
                android:minWidth="108dp"
                android:paddingStart="@dimen/spacing_18dp"
                android:paddingEnd="@dimen/spacing_18dp"
                android:text="@string/ui_upgrade_manager"
                android:textColor="@color/car_text_primary"
                android:textSize="@dimen/text_md" />

            <Button
                android:id="@+id/btnNavInstall"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginStart="@dimen/spacing_10dp"
                android:background="@drawable/bg_nav_button"
                android:minWidth="108dp"
                android:paddingStart="@dimen/spacing_18dp"
                android:paddingEnd="@dimen/spacing_18dp"
                android:text="@string/ui_install_manager"
                android:textColor="@color/car_text_primary"
                android:textSize="@dimen/text_md" />

            <Button
                android:id="@+id/btnNavMyApps"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginStart="@dimen/spacing_10dp"
                android:background="@drawable/bg_nav_button"
                android:minWidth="108dp"
                android:paddingStart="@dimen/spacing_18dp"
                android:paddingEnd="@dimen/spacing_18dp"
                android:text="@string/ui_my_apps"
                android:textColor="@color/car_text_primary"
                android:textSize="@dimen/text_md" />

            <Button
                android:id="@+id/btnNavDebug"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginStart="@dimen/spacing_10dp"
                android:background="@drawable/bg_nav_button"
                android:minWidth="108dp"
                android:paddingStart="@dimen/spacing_18dp"
                android:paddingEnd="@dimen/spacing_18dp"
                android:text="@string/ui_developer_settings"
                android:textColor="@color/car_text_primary"
                android:textSize="@dimen/text_md" />
        </LinearLayout>
    </HorizontalScrollView>

    <FrameLayout
        android:id="@+id/fragmentContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/spacing_12dp"
        android:layout_weight="1" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
