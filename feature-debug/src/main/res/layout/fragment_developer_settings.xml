<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_16dp">

        <!-- 环境切换面板 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_panel"
            android:orientation="vertical"
            android:padding="@dimen/spacing_18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/ui_download_environment_switch"
                android:textSize="@dimen/text_xl"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvCurrentEnvironment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_12dp"
                android:text="@string/ui_download_environment_current_format"
                android:textSize="@dimen/text_md"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvEnvironmentHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_8dp"
                android:text="@string/ui_download_environment_hint_dev"
                android:textSize="@dimen/text_sm" />

            <TextView
                android:id="@+id/tvCatalogSource"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_10dp"
                android:text="@string/ui_catalog_source_current_format"
                android:textSize="@dimen/text_sm" />

            <TextView
                android:id="@+id/tvDownloadBaseUrl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_6dp"
                android:text="@string/ui_debug_download_base_url_format"
                android:textSize="@dimen/text_sm" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_14dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnEnvDev"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/spacing_6dp"
                    android:layout_weight="1"
                    android:text="@string/ui_download_environment_switch_dev" />

                <Button
                    android:id="@+id/btnEnvTest"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_6dp"
                    android:layout_marginEnd="@dimen/spacing_6dp"
                    android:layout_weight="1"
                    android:text="@string/ui_download_environment_switch_test" />

                <Button
                    android:id="@+id/btnEnvProd"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_6dp"
                    android:layout_weight="1"
                    android:text="@string/ui_download_environment_switch_prod" />
            </LinearLayout>
        </LinearLayout>

        <!-- 策略信号面板 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_14dp"
            android:background="@drawable/bg_panel"
            android:orientation="vertical"
            android:padding="@dimen/spacing_18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/ui_debug_policy_signals"
                android:textSize="@dimen/text_xl"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvWifiStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_12dp"
                android:text="@string/ui_debug_wifi_status_format"
                android:textSize="@dimen/text_sm" />

            <TextView
                android:id="@+id/tvStorageStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_6dp"
                android:text="@string/ui_debug_storage_status_format"
                android:textSize="@dimen/text_sm" />

            <TextView
                android:id="@+id/tvParkingStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_6dp"
                android:text="@string/ui_debug_parking_status_format"
                android:textSize="@dimen/text_sm" />

            <Button
                android:id="@+id/btnRefreshSignals"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_14dp"
                android:text="@string/ui_debug_refresh_signals" />
        </LinearLayout>

        <!-- 版本信息面板 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_14dp"
            android:background="@drawable/bg_panel"
            android:orientation="vertical"
            android:padding="@dimen/spacing_18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/ui_debug_version_info"
                android:textSize="@dimen/text_xl"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvVersionInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_12dp"
                android:text="@string/ui_debug_version_format"
                android:textSize="@dimen/text_sm" />

            <TextView
                android:id="@+id/tvPackageName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_6dp"
                android:text="@string/ui_debug_package_format"
                android:textSize="@dimen/text_sm" />
        </LinearLayout>

        <!-- 缓存管理面板 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_14dp"
            android:background="@drawable/bg_panel"
            android:orientation="vertical"
            android:padding="@dimen/spacing_18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/ui_debug_cache_management"
                android:textSize="@dimen/text_xl"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnClearCache"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_14dp"
                android:text="@string/ui_debug_clear_cache" />
        </LinearLayout>

        <!-- 说明面板 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_14dp"
            android:background="@drawable/bg_panel"
            android:orientation="vertical"
            android:padding="@dimen/spacing_18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/ui_description"
                android:textSize="@dimen/text_lg"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_10dp"
                android:text="@string/ui_download_environment_description"
                android:textSize="@dimen/text_sm" />
        </LinearLayout>

    </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
